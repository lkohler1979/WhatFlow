# ============================================================
# WhatFlow — Variáveis de Ambiente (TEMPLATE)
# Copie para .env e preencha os valores reais.
# NUNCA comite o arquivo .env nem chaves reais neste template.
# ============================================================

# ── Banco de dados (Supabase) ──
DATABASE_URL="postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres"

# ── Supabase ──
SUPABASE_URL="https://[REF].supabase.co"
SUPABASE_ANON_KEY="eyJ...anon-key..."
SUPABASE_SERVICE_ROLE_KEY="eyJ...service-role-key..."
SUPABASE_JWT_SECRET="seu-jwt-secret-aqui"

# ── Evolution API ──
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="sua-chave-global-evolution"
EVOLUTION_WEBHOOK_SECRET="secret-hmac-para-validar-webhooks"

# ── IA — Groq (gratuito) ──
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.1-70b-versatile"

# ── IA — Ollama (local, alternativa) ──
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_DEFAULT_MODEL="mistral"

# ── Criptografia (AES-256 para chaves de IA no banco) ──
AI_ENCRYPTION_KEY="32-caracteres-exatos-aqui-000000"

# ── Redis (BullMQ) ──
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ── App ──
NODE_ENV="development"
PORT=3000
API_PREFIX="/v1"
JWT_SECRET="jwt-secret-proprio-aqui"
CORS_ORIGINS="http://localhost:4200"
LOG_LEVEL="debug"

# ── Rate limiting ──
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Frontend (Angular environment) ──
ANGULAR_API_URL="http://localhost:3000/v1"
SUPABASE_PUBLIC_URL="https://[REF].supabase.co"
SUPABASE_PUBLIC_ANON_KEY="eyJ...anon-key..."
