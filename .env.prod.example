# ─────────────────────────────────────────────────────────────────────────────
# WhatFlow — variáveis de PRODUÇÃO. Copie para .env.prod e preencha.
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
# NUNCA commite o .env.prod (está no .gitignore). Rotacione segredos expostos.
# ─────────────────────────────────────────────────────────────────────────────

# ── App / domínio ──
NODE_ENV=production
PORT=3000
# Domínio público (Cloudflare aponta para o IP do VPS). Usado no CORS da API.
CORS_ORIGINS=https://app.seu-dominio.com

# ── Banco (Supabase) — use o pooler IPv4 ──
DATABASE_URL=postgresql://postgres.<ref>:<senha>@aws-1-us-east-1.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.<ref>:<senha>@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# ── Supabase Auth (backend) ──
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=<kid-ou-segredo>

# ── Supabase (frontend — injetado no build do Angular via build args) ──
SUPABASE_PUBLIC_URL=https://<ref>.supabase.co
SUPABASE_PUBLIC_ANON_KEY=eyJ...

# ── Segurança app ──
JWT_SECRET=<segredo-forte>
AI_ENCRYPTION_KEY=<32-bytes-para-AES-256>

# ── Evolution API (WhatsApp) ──
# A chave global usada pela API e pela Evolution local do compose.
EVOLUTION_API_KEY=<chave-global-forte>
# URL pública do manager da Evolution (se for expor); interna por padrão.
EVOLUTION_SERVER_URL=http://evolution-api:8080
# Senha do Postgres da Evolution (troque do default!).
EVOLUTION_PG_PASSWORD=<senha-forte>
# Versão do WhatsApp Web (ver wppconnect-team/wa-version).
CONFIG_SESSION_PHONE_VERSION=2.3000.1042201107

# ── IA (Groq) ──
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
AI_PROVIDER=groq

# ── Redis ── (interno na rede do compose)
REDIS_URL=redis://redis:6379
