{
  "name": "whatflow",
  "private": true,
  "workspaces": ["apps/api", "apps/web"],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev --workspace=apps/api\" \"npm run start --workspace=apps/web\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run e2e --workspace=apps/web",
    "prisma:migrate": "npm run prisma:migrate --workspace=apps/api",
    "prisma:generate": "npm run prisma:generate --workspace=apps/api",
    "prisma:studio": "npm run prisma:studio --workspace=apps/api",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "apps/api/src/**/*.ts": ["eslint --fix", "prettier --write"],
    "apps/web/src/**/*.{ts,html,scss}": ["prettier --write"]
  }
}
