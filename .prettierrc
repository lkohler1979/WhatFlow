{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "tabWidth": 2,
  "endOfLine": "lf",
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "overrides": [
    {
      "files": "*.html",
      "options": { "parser": "html", "printWidth": 120 }
    },
    {
      "files": "*.scss",
      "options": { "singleQuote": false }
    }
  ]
}
